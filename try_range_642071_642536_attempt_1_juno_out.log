      --http-port uint16                  The port on which the HTTP server will listen for requests. (default 6060)
      --log-level LogLevel                Options: debug, info, warn, error. (default info)
      --max-vm-queue uint                 Maximum number for requests to queue after reaching max-vms before starting to reject incoming requets (default 48)
      --max-vms uint                      Maximum number for VM instances to be used for RPC calls concurrently (default 24)
